# Copy to `.env` and fill in. Loaded by src/agent_workspaces/config.py.
# NOTE: never commit real secrets. In the target architecture, credentials do NOT
# live in the sandbox at all — they route through the credential proxy (see
# src/agent_workspaces/security/credential_proxy.py). These are control-plane settings.

# --- App ---
AWS_ENV=local                        # local | staging | prod  (prefix is AWS_ = Agent WorkspaceS)
AWS_LOG_LEVEL=INFO
AWS_API_HOST=0.0.0.0
AWS_API_PORT=8000

# --- Control plane (warm pools / scheduler) ---
AWS_WARM_POOL_MIN_SIZE=2             # sandboxes kept hot at all times
AWS_WARM_POOL_MAX_SIZE=16            # ceiling for pre-provisioned sandboxes
AWS_WARM_POOL_IDLE_TTL_SECONDS=900   # evict warm sandboxes idle longer than this

# --- Execution plane (sandbox runtime) ---
AWS_RUNTIME_BACKEND=mock             # mock | docker | firecracker | k8s  (TODO: implement)
AWS_SANDBOX_BASE_IMAGE=agent-workspace:base   # versioned base snapshot
AWS_SANDBOX_MAX_LIFETIME_SECONDS=3600

# --- Security & network plane ---
AWS_CREDENTIAL_PROXY_URL=http://localhost:8081   # secrets stay behind this proxy
AWS_EGRESS_ALLOWLIST=github.com,pypi.org         # comma-separated outbound allowlist
AWS_INGRESS_ALLOWLIST=                            # empty = deny all inbound by default

# --- Data plane ---
AWS_DATASET_SNAPSHOT_URI=            # TODO: URI of the read-only reference snapshot
AWS_DATA_BRANCH_BACKEND=mock         # mock | zfs | neon | copy-on-write (TODO: implement)

# --- Trace store ---
AWS_TRACE_STORE_URI=                 # TODO: where execution traces persist (s3://..., postgres://...)
